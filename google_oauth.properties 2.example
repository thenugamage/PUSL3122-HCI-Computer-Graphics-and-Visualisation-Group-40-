# Lanka Furniture Visualizer - Google OAuth Configuration Template
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project
# 3. Configure OAuth consent screen
# 4. Create OAuth 2.0 Client ID (Desktop Application)
# 5. Copy the Client ID and Secret here
# 6. Rename this file to 'google_oauth.properties' and place it in src/main/resources/

GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Remote Database Configuration (Optional)
# If using a centralized database (PostgreSQL), provide the JDBC URL here.
# Example: jdbc:postgresql://your-db-host:5432/your-db-name?user=your-user&password=your-password
REMOTE_DB_URL=
